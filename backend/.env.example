# Copia este archivo como .env y completa los valores reales.
# El .env NO se sube al repo (está en .gitignore).

# --- Django ---
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=America/La_Paz

# --- PostgreSQL local (dev) ---
DB_NAME=erp_dev
DB_USER=postgres
DB_PASSWORD=tu_password_de_postgres
DB_HOST=127.0.0.1
DB_PORT=5432

# --- CORS (orígenes del frontend/PWA) ---
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
